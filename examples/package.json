{
  "name": "@melviz/examples",
  "version": "0.0.0",
  "description": "Melviz Dashboard Examples Gallery",
  "private": true,
  "scripts": {
    "clean": "rimraf dist",
    "generate-samples": "node scripts/generate-samples.js",
    "copy-melviz": "node scripts/copy-melviz.js",
    "copy-dashboards": "node scripts/copy-dashboards.js",
    "build": "yarn clean && yarn generate-samples && yarn copy-melviz && yarn copy-dashboards",
    "serve": "npx http-server dist -c-1 -p 8080 -o",
    "dev": "node scripts/dev-server.js"
  },
  "dependencies": {
    "@melviz/webapp": "0.0.0"
  },
  "keywords": [
    "melviz",
    "dashboard",
    "examples"
  ],
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "browser-sync": "^2.29.3",
    "chokidar": "^3.5.3",
    "http-server": "^14.1.1",
    "rimraf": "^6.1.3"
  }
}
